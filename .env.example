# ============================================================
# PHOENIX TRADING DASHBOARD — Environment Variables
# Copy this to .env.local for development
# Add these in Vercel Dashboard → Settings → Environment Variables
# ============================================================

# ── Claude AI (required for agent pipeline) ──────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── MT5 Bot Authentication (optional but recommended) ────
# Set a strong random string here AND in your EA's PhoenixSecret input
# Generate one: openssl rand -hex 32
MT5_PUSH_SECRET=your-secret-here

# ── Firebase (optional — for persistent storage) ─────────
# Replace the in-memory store in lib/store.ts when ready
# FIREBASE_PROJECT_ID=phoenix-dashboard
# FIREBASE_CLIENT_EMAIL=...
# FIREBASE_PRIVATE_KEY=...

# ── External Data APIs (optional — for live news/calendar) ─
# Replace MOCK_NEWS / MOCK_CALENDAR in lib/mock-data.ts
# POLYGON_API_KEY=...
# FOREXFACTORY_FEED_URL=...
