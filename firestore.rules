rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// PHOENIX TRADING ECOSYSTEM — Security Rules
//
// Data model:
//   {path=**}/trades/{id} — user trades, scoped by userId (manual & subcollections)
//   botTrades/{id}        — bot trades, shared/public read-only (demo feed)
//   notes/{id}            — per-asset, per-user notes (id = {userId}_{symbol})
//   allowedUsers/{uid}    — VIP whitelist, capped at 15
//   marketBias/* — public cache of Claude analysis
//   signals/* — public bot signals (if used)
//
// Server-side writes (webhooks, sync scripts) use the Admin SDK and
// bypass these rules completely.
// Client-side writes are securely restricted to authenticated user scope.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isOnAllowedList() {
      return isSignedIn() && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid));
    }

    // ── trades — Collection Group Rule (Root & Subcollections) ──
    // Supports group queries for multi-account syncing while enforcing strict user isolation.
    match /{path=**}/trades/{tradeId} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if isOnAllowedList()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                            && resource.data.userId == request.auth.uid;
    }

    // ── botTrades — shared demo feed (bots' history) ────────
    // ANY whitelisted signed-in user can read. Only Admin SDK handles writes.
    match /botTrades/{tradeId} {
      allow read: if isOnAllowedList();
      allow write: if false;
    }

    // ── notes — per-asset, per-user (id format: {uid}_{symbol}) ──
    match /notes/{noteId} {
      allow read: if isOnAllowedList()
                  && resource.data.userId == request.auth.uid;
      allow create, update: if isOnAllowedList()
                            && request.resource.data.userId == request.auth.uid
                            && noteId == request.auth.uid + "_" + request.resource.data.symbol;
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // ── allowedUsers — VIP whitelist (read by all auth, write Admin SDK only) ──
    match /allowedUsers/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── marketBias — public Claude analysis cache ───────────
    match /marketBias/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── signals — public bot signals ────────────────────────
    match /signals/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── pushSubscriptions — web-push device registrations ────
    // A signed-in user may create/update/delete their OWN subscription doc
    // (doc id is a hash of the push endpoint). The server (Admin SDK) reads
    // all of them to send notifications and bypasses these rules.
    match /pushSubscriptions/{subId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── tickerCache — public last-good market ticker values ──
    // Read by anyone signed in; written only by the server (Admin SDK).
    match /tickerCache/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Deny everything else by default ─────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}